# ==============================================================================
# SinyalTender Environment Configuration
# ==============================================================================

# General
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3000

# Database & Cache
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/sinyaltender?schema=public"
# Redis configurations for background queues and scraper cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication (NextAuth.js & NestJS JWT)
NEXTAUTH_SECRET=generate-a-32-character-random-string-here
JWT_SECRET=super-secret-nestjs-jwt-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Payment Integration (Midtrans)
# Sandbox or Production credentials
MIDTRANS_MERCHANT_ID=Gxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# AI Engine (Google Gemini)
# API key to process tender PDFs/HTM into structured JSON summaries
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# LPSE Scraper Sources (SPSE INAPROC DataTable API)
# JSON array of { name, baseUrl, slug, apiSlug, location }
# baseUrl: the LPSE page (e.g. https://spse.inaproc.id/kemenkeu)
# slug: internal identifier (e.g. LPSE_KEMEN_KEU)
# apiSlug: URL path segment (e.g. kemenkeu)
# LPSE_URLS='[{"name":"LPSE Kemenkeu","baseUrl":"https://spse.inaproc.id/kemenkeu","slug":"LPSE_KEMEN_KEU","apiSlug":"kemenkeu","location":"DKI Jakarta"}]'

# Alerts & Notifications Channels
# Telegram Bot Token & API Configurations
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ-123456
# Resend API or SMTP configurations for email notification dispatch
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=no-reply@sinyaltender.id
